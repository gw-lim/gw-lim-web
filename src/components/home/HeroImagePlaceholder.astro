---
interface Props {
  label: string;
  height?: number;
  class?: string;
}

const { label, height = 200, class: className } = Astro.props;
const id = `stripe-${label.replace(/[^a-zA-Z0-9]/g, '')}-${Math.random().toString(36).slice(2, 8)}`;
---

<svg
  width="100%"
  height={height}
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  style="display: block;"
  aria-hidden="true"
>
  <defs>
    <pattern
      id={id}
      patternUnits="userSpaceOnUse"
      width="12"
      height="12"
      patternTransform="rotate(45)"
    >
      <rect width="12" height="12" fill="#f4f4f4"></rect>
      <rect width="6" height="12" fill="#e8e8e8"></rect>
    </pattern>
  </defs>
  <rect width="100%" height={height} fill={`url(#${id})`}></rect>
  <text
    x="50%"
    y="50%"
    dominant-baseline="middle"
    text-anchor="middle"
    font-family="'JetBrains Mono', monospace"
    font-size="11"
    fill="#aaaaaa"
    letter-spacing="0.04em">{label}</text
  >
</svg>
