---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../../utils/date';
import { calcReadTime } from '../../utils/readTime';

interface Props {
  post: CollectionEntry<'posts'>;
  showImg?: boolean;
  last?: boolean;
}

const { post, showImg = true, last = false } = Astro.props;
const readTime = calcReadTime(post.body);
---

<a href={`/blog/${post.id}`} class="recent-card group relative block">
  <article
    class:list={[
      'relative grid items-center gap-4 py-5',
      showImg ? 'grid-cols-[1fr_96px]' : 'grid-cols-1',
      !last && 'border-b border-[var(--border)]',
    ]}
  >
    <span
      class="pointer-events-none absolute -left-5 bottom-0 top-0 w-[2px] origin-center scale-y-[0.2] bg-ink opacity-0 transition-[opacity,transform] duration-200 ease-out group-hover:scale-y-100 group-hover:opacity-100"
      aria-hidden="true"></span>

    <div>
      <div class="mb-2 flex flex-wrap gap-1.5">
        {
          post.data.tags.map((tag) => (
            <span class="inline-block whitespace-nowrap rounded-[4px] bg-[var(--tag-bg)] px-2 py-[2px] text-[11px] font-medium tracking-[0.01em] text-[var(--tag-text)]">
              #{tag}
            </span>
          ))
        }
      </div>
      <h3
        class="recent-title mb-1.5 text-[16px] font-semibold leading-[1.5] tracking-[-0.01em] text-ink"
        style="text-wrap: pretty;"
      >
        {post.data.title}
      </h3>
      <div class="mt-2.5 flex items-center gap-2">
        <time datetime={post.data.createdAt} class="text-[11.5px] text-ink-faint">
          {formatDate(post.data.createdAt)}
        </time>
        <span class="text-[11.5px] text-ink-faint">·</span>
        <span class="text-[11.5px] text-ink-faint">{readTime} 읽기</span>
      </div>
    </div>

    {
      showImg && (
        <div class="h-[72px] w-24 flex-shrink-0 overflow-hidden rounded-[6px] border border-[var(--border)]">
          <div class="h-full w-full transition-transform duration-[350ms] ease-out group-hover:scale-[1.05]">
            <img
              src={post.data.thumbnail}
              alt={post.data.title}
              width="96"
              height="72"
              style="display: block; width: 100%; height: 72px; object-fit: cover;"
            />
          </div>
        </div>
      )
    }
  </article>
</a>

<style>
  .recent-card:hover .recent-title {
    text-decoration: underline;
    text-decoration-color: var(--border-strong);
    text-underline-offset: 3px;
  }
</style>
