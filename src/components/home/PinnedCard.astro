---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../../utils/date';
import { calcReadTime } from '../../utils/readTime';

interface Props {
  post: CollectionEntry<'posts'>;
  showImg?: boolean;
}

const { post, showImg = true } = Astro.props;
const readTime = calcReadTime(post.body);
---

<a href={`/blog/${post.id}`} class="pinned-card group block">
  <article
    class="overflow-hidden rounded-[10px] border border-[var(--border)] bg-bg shadow-[0_1px_4px_rgba(0,0,0,0.04)] transition-[transform,box-shadow] duration-200 ease-out group-hover:-translate-y-[3px] group-hover:shadow-[0_8px_22px_rgba(0,0,0,0.063)]"
  >
    {
      showImg && (
        <div class="relative overflow-hidden">
          <div class="transition-transform duration-[400ms] ease-out group-hover:scale-[1.021]">
            <img
              src={post.data.thumbnail}
              alt={post.data.title}
              width="600"
              height="180"
              style="display: block; width: 100%; height: 180px; object-fit: cover;"
            />
          </div>
        </div>
      )
    }
    <div class="px-[22px] pb-[22px] pt-5">
      <div class="mb-2.5 flex flex-wrap gap-1.5">
        {
          post.data.tags.map((tag) => (
            <span class="inline-block whitespace-nowrap rounded-[4px] bg-[var(--tag-bg)] px-2 py-[2px] text-[11px] font-medium tracking-[0.01em] text-[var(--tag-text)]">
              #{tag}
            </span>
          ))
        }
      </div>
      <h3
        class="mb-2 text-[17px] font-bold leading-[1.5] tracking-[-0.02em] text-ink"
        style="text-wrap: pretty;"
      >
        {post.data.title}
      </h3>
      <p class="mb-3.5 text-[13.5px] leading-[1.65] text-ink-muted">
        {post.data.description}
      </p>
      <div class="flex items-center gap-2">
        <time datetime={post.data.createdAt} class="text-[12px] text-ink-faint">
          {formatDate(post.data.createdAt)}
        </time>
        <span class="text-[12px] text-ink-faint">·</span>
        <span class="text-[12px] text-ink-faint">{readTime} 읽기</span>
      </div>
    </div>
  </article>
</a>
