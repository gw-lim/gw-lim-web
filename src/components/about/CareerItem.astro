---
import type { CollectionEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'careers'>;
}

const { item } = Astro.props;
const { role, organizationName, startedAt, endedAt, body } = item.data;
const period = endedAt ? `${startedAt} – ${endedAt}` : `${startedAt} – Present`;
---

<div class="entry">
  <div class="entry-grid">
    <div class="entry-meta">
      <p class="entry-org">{organizationName}</p>
      <p class="entry-role">{role}</p>
      <p class="entry-period">{period}</p>
    </div>
    <div class="entry-body">
      {
        body.map((section) => (
          <div class="proj">
            <h3 class="proj-title">{section.heading}</h3>
            {section.description && <p class="proj-desc">{section.description}</p>}
            {section.lists.length > 0 && (
              <ul class="proj-list">
                {section.lists.map((line) => (
                  <li>{line}</li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .entry + .entry {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e7eb;
  }

  .entry-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .entry-grid {
      grid-template-columns: 160px 1fr;
      gap: 1.5rem;
    }
  }

  @media (min-width: 1000px) {
    .entry-grid {
      grid-template-columns: 200px 1fr;
      gap: 2rem;
    }
  }

  .entry-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .entry-org {
    margin: 0;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(45, 45, 45, 0.6);
  }

  .entry-role {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 700;
    color: #1d1d1f;
    line-height: 1.3;
  }

  .entry-period {
    margin: 0.125rem 0 0;
    font-size: 0.72rem;
    color: rgba(45, 45, 45, 0.6);
    font-variant-numeric: tabular-nums;
  }

  .entry-body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .proj {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-left: 0.875rem;
    border-left: 2px solid rgba(45, 45, 45, 0.18);
  }

  .proj-title {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 700;
    color: #1d1d1f;
    line-height: 1.4;
  }

  .proj-desc {
    margin: 0;
    font-size: 0.75rem;
    line-height: 1.5;
    color: rgba(45, 45, 45, 0.6);
  }

  .proj-list {
    margin: 0.5rem 0 0;
    padding-left: 1rem;
    list-style: disc;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .proj-list li {
    font-size: 0.775rem;
    line-height: 1.65;
    color: #2d2d2d;
  }
</style>
