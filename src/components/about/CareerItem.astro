---
import type { CollectionEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'careers'>;
}

const { item } = Astro.props;
const { role, organizationName, startedAt, endedAt, stack, body } = item.data;
const period = endedAt ? `${startedAt} – ${endedAt}` : `${startedAt} – Present`;
---

<div class="entry">
  <div class="entry-grid">
    <div class="entry-meta">
      <p class="entry-org">{organizationName}</p>
      <p class="entry-role">{role}</p>
      <p class="entry-period">{period}</p>
      {
        stack.length > 0 && (
          <ul class="entry-stack" aria-label="기술 스택">
            {stack.map((tech) => (
              <li class="entry-stack-item">{tech}</li>
            ))}
          </ul>
        )
      }
    </div>
    <div class="entry-body">
      {
        body.map((section) => (
          <div class="proj">
            <h3 class="proj-title">{section.heading}</h3>
            {section.description && <p class="proj-desc">{section.description}</p>}
            {section.lists.length > 0 && (
              <ul class="proj-list">
                {section.lists.map((line) => (
                  <li>{line}</li>
                ))}
              </ul>
            )}
            {section.links.length > 0 && (
              <ul class="proj-links" aria-label="관련 글">
                {section.links.map((link) => (
                  <li>
                    <a class="proj-link" href={link.href}>
                      <svg
                        class="proj-link-icon"
                        width="10"
                        height="10"
                        viewBox="0 0 12 12"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.6"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M3.5 8.5 8.5 3.5" />
                        <path d="M4 3.5h4.5V8" />
                      </svg>
                      <span>{link.label}</span>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .entry + .entry {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e7eb;
  }

  .entry-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .entry-grid {
      grid-template-columns: 160px 1fr;
      gap: 1.5rem;
    }
  }

  @media (min-width: 1000px) {
    .entry-grid {
      grid-template-columns: 200px 1fr;
      gap: 2rem;
    }
  }

  .entry-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .entry-org {
    margin: 0;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(45, 45, 45, 0.6);
  }

  .entry-role {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 700;
    color: #1d1d1f;
    line-height: 1.3;
  }

  .entry-period {
    margin: 0.125rem 0 0;
    font-size: 0.72rem;
    color: rgba(45, 45, 45, 0.6);
    font-variant-numeric: tabular-nums;
  }

  .entry-stack {
    margin: 0.625rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .entry-stack-item {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.4rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    font-weight: 500;
    line-height: 1.3;
    color: rgba(45, 45, 45, 0.72);
    background: rgba(45, 45, 45, 0.04);
    border: 1px solid rgba(45, 45, 45, 0.12);
    border-radius: 3px;
    white-space: nowrap;
  }

  @media print {
    .entry-stack-item {
      background: transparent;
    }
  }

  .entry-body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .proj {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-left: 0.875rem;
    border-left: 2px solid rgba(45, 45, 45, 0.18);
  }

  .proj-title {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 700;
    color: #1d1d1f;
    line-height: 1.4;
  }

  .proj-desc {
    margin: 0;
    font-size: 0.75rem;
    line-height: 1.5;
    color: rgba(45, 45, 45, 0.6);
  }

  .proj-list {
    margin: 0.5rem 0 0;
    padding-left: 1rem;
    list-style: disc;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .proj-list li {
    font-size: 0.775rem;
    line-height: 1.65;
    color: #2d2d2d;
  }

  .proj-links {
    margin: 0.4rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .proj-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.55rem;
    font-size: 0.7rem;
    line-height: 1.2;
    color: rgba(38, 38, 38, 0.65);
    text-decoration: none;
    background: #ffffff;
    border: 1px solid rgba(38, 38, 38, 0.22);
    border-radius: 4px;
    transition:
      background 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease;
  }

  .proj-link:hover,
  .proj-link:focus-visible {
    background: #3b3b3f;
    color: #ffffff;
    border-color: #3b3b3f;
  }

  .proj-link:focus-visible {
    outline: 2px solid #3b3b3f;
    outline-offset: 2px;
  }

  .proj-link-icon {
    flex-shrink: 0;
  }

  @media print {
    .proj-link {
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
  }
</style>
