---
import type { CollectionEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'certifications'>;
}

const { item } = Astro.props;
const { name, issuer, issuedAt } = item.data;
---

<div class="cert-card">
  <p class="cert-org">{issuer}</p>
  <h3 class="cert-name">{name}</h3>
  <p class="cert-date">Issued {issuedAt}</p>
</div>

<style>
  .cert-card {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem 1.25rem;
    background: #ffffff;
  }

  .cert-org {
    margin: 0;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: rgba(45, 45, 45, 0.6);
  }

  .cert-name {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 700;
    color: #1d1d1f;
  }

  .cert-date {
    margin: 0.125rem 0 0;
    font-size: 0.7rem;
    color: rgba(45, 45, 45, 0.6);
  }
</style>
