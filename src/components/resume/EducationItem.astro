---
import type { CollectionEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'education'>;
}

const { item } = Astro.props;
const { school, major, degree, startedAt, endedAt } = item.data;
---

<div class="flex gap-6">
  <div class="w-36 flex-shrink-0 pt-1 text-sm text-gray-400">
    {startedAt} — {endedAt ?? '현재'}
  </div>
  <div class="flex-1">
    <h3 class="font-semibold">{school}</h3>
    <p class="text-sm text-gray-500">
      {major} · {degree}
    </p>
  </div>
</div>
