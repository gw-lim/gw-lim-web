---
import type { CollectionEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'certifications'>;
}

const { item } = Astro.props;
const { name, issuer, issuedAt, expiresAt } = item.data;
---

<div class="flex gap-6">
  <div class="w-36 flex-shrink-0 pt-1 text-sm text-gray-400">
    {issuedAt}
    {expiresAt && ` — ${expiresAt}`}
  </div>
  <div class="flex-1">
    <h3 class="font-semibold">{name}</h3>
    <p class="text-sm text-gray-500">{issuer}</p>
  </div>
</div>
