---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  items.length > 0 && (
    <details class="group mb-4 rounded border border-ink-border bg-bg-subtle min-[1080px]:hidden">
      <summary
        class="flex cursor-pointer list-none items-center justify-between px-4 py-3 [&::-webkit-details-marker]:hidden"
        data-toc-mobile-summary
      >
        <span class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.09em] text-ink-faint">
          목차 · {items.length}
        </span>
        <svg
          class="h-3 w-3 text-ink-faint transition-transform duration-150 group-open:rotate-180"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z" />
        </svg>
      </summary>
      <ul class="m-0 list-none border-t border-ink-border px-2 py-1.5">
        {items.map((item) => (
          <li class="p-0">
            <a
              href={`#${item.slug}`}
              class={
                item.depth === 3
                  ? 'block py-1.5 pl-7 text-[12px] leading-[1.5] text-ink-muted no-underline'
                  : 'block py-1.5 pl-3 text-[12.5px] leading-[1.5] text-ink-muted no-underline'
              }
            >
              {item.text}
            </a>
          </li>
        ))}
      </ul>
    </details>
  )
}
