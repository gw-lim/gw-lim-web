---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../../utils/date';

interface Props {
  post: CollectionEntry<'posts'>;
  seriesName?: string;
  readTime: string;
}

const { post, seriesName, readTime } = Astro.props;
const tagsAttr = post.data.tags.join(',');
---

<article
  class="post-row group relative grid grid-cols-[1fr_96px] items-center gap-4 border-b border-ink-border py-[22px] last:border-b-0"
  data-tags={tagsAttr}
>
  <span
    aria-hidden="true"
    class="pointer-events-none absolute -left-6 bottom-0 top-0 w-[2px] origin-center scale-y-[0.15] bg-ink opacity-0 transition-[opacity,transform] duration-200 ease-in-out group-hover:scale-y-100 group-hover:opacity-100"
  ></span>

  <div>
    <div class="mb-2 flex flex-wrap items-center gap-2">
      {
        seriesName && (
          <span class="inline-block whitespace-nowrap rounded border border-ink-border px-[7px] py-px font-mono text-[10px] font-medium tracking-[0.04em] text-ink-faint">
            {seriesName}
          </span>
        )
      }
      <div class="flex flex-wrap gap-[5px]">
        {
          post.data.tags.map((tag) => (
            <span class="inline-block whitespace-nowrap rounded bg-tag-bg px-2 py-0.5 text-[11px] font-medium tracking-[0.01em] text-tag-text">
              #{tag}
            </span>
          ))
        }
      </div>
    </div>
    <h3
      class="mb-[5px] break-words text-[15.5px] font-semibold leading-[1.5] tracking-[-0.015em] text-ink underline-offset-[3px] group-hover:underline group-hover:decoration-ink-border-strong"
    >
      <a href={`/blog/${post.id}`} class="after:absolute after:inset-0 after:content-['']">
        {post.data.title}
      </a>
    </h3>
    <p class="mb-2.5 break-all text-[13px] leading-[1.6] text-ink-muted">
      {post.data.description}
    </p>
    <div class="flex items-center gap-2">
      <time datetime={post.data.createdAt} class="text-[11.5px] text-ink-faint">
        {formatDate(post.data.createdAt)}
      </time>
      <span class="text-[11.5px] text-ink-faint">·</span>
      <span class="text-[11.5px] text-ink-faint">{readTime} 읽기</span>
    </div>
  </div>

  <div class="h-[72px] w-24 flex-shrink-0 overflow-hidden rounded-md border border-ink-border">
    <img
      src={post.data.thumbnail}
      alt={post.data.title}
      width="96"
      height="72"
      class="block h-full w-full object-cover transition-transform duration-[350ms] ease-in-out group-hover:scale-105"
    />
  </div>
</article>
