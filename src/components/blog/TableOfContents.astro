---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);

const baseLinkClass =
  'block text-[12px] leading-[1.5] no-underline py-[3px] border-l-2 transition-colors duration-150 hover:text-ink-muted text-ink-faint border-ink-border';
---

{
  items.length > 0 && (
    <nav
      class="fixed right-[max(24px,calc(50vw-580px))] top-[88px] hidden max-h-[calc(100vh-120px)] w-[196px] overflow-y-auto [scrollbar-width:none] min-[1080px]:block [&::-webkit-scrollbar]:hidden"
      aria-label="목차"
      data-toc
    >
      <div class="text-ink-faint mb-3 font-mono text-[10.5px] font-semibold uppercase tracking-[0.09em]">
        목차
      </div>
      <ul class="m-0 list-none p-0">
        {items.map((item) => (
          <li class="p-0">
            <a
              href={`#${item.slug}`}
              data-toc-link={item.slug}
              data-depth={item.depth}
              class={
                item.depth === 3
                  ? `${baseLinkClass} pl-[22px] text-[11.5px]`
                  : `${baseLinkClass} pl-3`
              }
            >
              {item.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script>
  const toc = document.querySelector<HTMLElement>('[data-toc]');
  if (toc) {
    const links = Array.from(toc.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'));

    const ACTIVE_CLASSES = ['text-ink', 'border-ink', 'font-semibold'];
    const INACTIVE_CLASSES = ['text-ink-faint', 'border-ink-border'];

    const setActive = (slug: string) => {
      links.forEach((a) => {
        const isActive = a.dataset.tocLink === slug;
        if (isActive) {
          a.classList.remove(...INACTIVE_CLASSES);
          a.classList.add(...ACTIVE_CLASSES);
        } else {
          a.classList.remove(...ACTIVE_CLASSES);
          a.classList.add(...INACTIVE_CLASSES);
        }
      });
    };

    const targets = links
      .map((a) => document.getElementById(a.dataset.tocLink!))
      .filter((el): el is HTMLElement => el !== null);

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((e) => e.isIntersecting).map((e) => e.target.id);
        if (visible.length > 0) setActive(visible[0]);
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0 },
    );

    targets.forEach((t) => observer.observe(t));
  }
</script>
