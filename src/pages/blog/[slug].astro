---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GiscusComments from '../../components/Giscus';
import SeriesPostList from '../../components/blog/SeriesPostList.astro';
import PostNav from '../../components/blog/PostNav.astro';
import TableOfContents from '../../components/blog/TableOfContents.astro';
import TableOfContentsMobile from '../../components/blog/TableOfContentsMobile.astro';
import { formatDate } from '../../utils/date';
import { getSeriesPosts } from '../../utils/collection';
import { calcReadTime } from '../../utils/readTime';
import dayjs from 'dayjs';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const series = await getCollection('series');

  const sortedPosts = [...posts].sort(
    (a, b) => dayjs(a.data.createdAt).valueOf() - dayjs(b.data.createdAt).valueOf(),
  );

  return posts.map((post) => {
    const seriesEntry = post.data.seriesId
      ? series.find((s) => s.data.id === post.data.seriesId)
      : undefined;
    const seriesPosts = seriesEntry ? getSeriesPosts(posts, seriesEntry.data.id) : [];

    return {
      params: { slug: post.id },
      props: { post, series: seriesEntry, seriesPosts, allPosts: sortedPosts },
    };
  });
}

const { post, series, seriesPosts, allPosts } = Astro.props;
const { Content, headings } = await render(post);
const readTime = calcReadTime(post.body);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  thumbnail={post.data.thumbnail}
>
  <TableOfContents headings={headings} slot="aside" />

  <header class="fade-in pb-4 pt-14">
    {
      series && (
        <div class="mb-3.5">
          <div class="inline-block rounded border border-ink-border px-[9px] py-0.5 font-mono text-[11px] font-medium tracking-[0.04em] text-ink-faint no-underline transition-colors duration-150">
            시리즈 · {series.data.name}
          </div>
        </div>
      )
    }

    <h1
      class="mb-4 break-keep text-[clamp(24px,4vw,34px)] font-extrabold leading-[1.25] tracking-[-0.03em] text-ink"
    >
      {post.data.title}
    </h1>

    <p class="mb-5 break-all text-[15px] leading-[1.7] text-ink-muted">
      {post.data.description}
    </p>

    <div class="mb-5 flex flex-wrap items-center gap-2.5">
      <time datetime={post.data.createdAt} class="text-[12.5px] text-ink-faint">
        {formatDate(post.data.createdAt)}
      </time>
      <span class="text-[12.5px] text-ink-border-strong">·</span>
      <span class="text-[12.5px] text-ink-faint">약 {readTime} 읽기</span>
      {
        post.data.tags.length > 0 && (
          <>
            <span class="text-[12.5px] text-ink-border-strong">·</span>
            <div class="flex flex-wrap gap-1.5">
              {post.data.tags.map((tag) => (
                <a
                  href={`/blog/tags/${encodeURIComponent(tag)}`}
                  class="inline-block whitespace-nowrap rounded bg-tag-bg px-2 py-0.5 text-[11px] font-medium tracking-[0.01em] text-tag-text no-underline"
                >
                  #{tag}
                </a>
              ))}
            </div>
          </>
        )
      }
    </div>
  </header>

  <TableOfContentsMobile headings={headings} />

  <article class="prose prose-gray max-w-none pt-4">
    <Content />
  </article>

  {
    series && (
      <section class="mt-4">
        <SeriesPostList series={series} posts={seriesPosts} currentPostId={post.id} />
      </section>
    )
  }

  <PostNav posts={allPosts} currentPostId={post.id} />

  <section class="mt-16 border-t border-ink-border pb-8 pt-10">
    <GiscusComments client:only="react" />
  </section>
</BaseLayout>
