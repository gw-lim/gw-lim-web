---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/blog/PostCard.astro';
import { sortByDate } from '../utils/collection';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const recentPosts = sortByDate(allPosts).slice(0, 3);
---

<BaseLayout title="Home" description="개인 홈페이지">
  <section class="mb-16">
    <h1 class="mb-4 text-4xl font-bold">안녕하세요, Geon입니다.</h1>
    <p class="text-lg text-gray-500">개발자입니다. 블로그와 이력서를 확인해보세요.</p>
    <div class="mt-6 flex gap-4">
      <a
        href="/blog"
        class="rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-700"
      >
        블로그 보기
      </a>
      <a
        href="/resume"
        class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium hover:bg-gray-50"
      >
        이력서 보기
      </a>
    </div>
  </section>

  {
    recentPosts.length > 0 && (
      <section>
        <div class="mb-6 flex items-center justify-between">
          <h2 class="text-2xl font-semibold">최근 포스트</h2>
          <a href="/blog" class="text-sm text-blue-600 hover:underline">
            전체 보기 →
          </a>
        </div>
        {recentPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </section>
    )
  }
</BaseLayout>
