---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PinnedCard from '../components/home/PinnedCard.astro';
import RecentCard from '../components/home/RecentCard.astro';
import { sortByDate } from '../utils/collection';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sorted = sortByDate(allPosts);
const pinnedPosts = sorted.filter((p) => p.data.pinned);
const recentPosts = sorted.slice(0, 5);
---

<BaseLayout description="Software Engineer gw-lim의 개발 블로그입니다.">
  {/* HERO */}
  <section class="fade-in pb-14 pt-[68px]">
    <div class="mb-2">
      <span
        class="text-ink-faint inline-block whitespace-nowrap rounded-[4px] border border-[var(--border)] px-[9px] py-[2px] font-mono text-[12px] font-medium tracking-[0.04em]"
      >
        Software Engineer
      </span>
    </div>
    <h1
      class="text-ink mb-4 font-extrabold leading-[1.2] tracking-[-0.03em]"
      style="font-size: clamp(32px, 5vw, 46px);"
    >
      안녕하세요,<br />gw-lim입니다.
    </h1>
    <div class="flex gap-2.5">
      <a
        href="/blog"
        class="hero-btn-secondary text-ink-muted inline-flex items-center rounded-[7px] border-[1.5px] border-[var(--border)] bg-transparent px-5 py-[9px] text-[14px] font-semibold no-underline transition-all duration-150"
      >
        블로그 보기
      </a>
    </div>
  </section>

  <div class="h-px bg-[var(--border)]"></div>

  {/* 눈여겨볼 글 */}
  {
    pinnedPosts.length > 0 && (
      <>
        <section class="fade-in pt-[44px]">
          <div class="mb-6 flex items-baseline justify-between">
            <h2 class="text-ink whitespace-nowrap text-[19px] font-bold tracking-[-0.02em]">
              눈여겨볼 글
            </h2>
          </div>
          <div class="grid grid-cols-[repeat(auto-fill,minmax(300px,1fr))] gap-4 pb-[52px]">
            {pinnedPosts.map((post) => (
              <PinnedCard post={post} />
            ))}
          </div>
        </section>
        <div class="h-px bg-[var(--border)]" />
      </>
    )
  }

  {/* 최근 포스트 */}
  {
    recentPosts.length > 0 && (
      <section class="fade-in pt-[52px]">
        <div class="mb-6 flex items-baseline justify-between">
          <h2 class="text-ink whitespace-nowrap text-[19px] font-bold tracking-[-0.02em]">
            최근 포스트
          </h2>
          <a
            href="/blog"
            class="section-link text-ink-faint text-[13px] font-medium no-underline transition-colors duration-150"
          >
            전체 보기 →
          </a>
        </div>
        <div class="pb-[52px]">
          {recentPosts.map((post, i) => (
            <RecentCard post={post} last={i === recentPosts.length - 1} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .hero-btn-primary:hover {
    background: #222;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
  }
  .hero-btn-secondary:hover {
    color: var(--ink);
    border-color: var(--border-strong);
    transform: translateY(-1px);
  }
  .section-link:hover {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
