---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CareerItem from '../../components/about/CareerItem.astro';
import ActivityItem from '../../components/about/ActivityItem.astro';
import EducationItem from '../../components/about/EducationItem.astro';
import CertItem from '../../components/about/CertItem.astro';

const careers = await getCollection('careers');
const activities = await getCollection('activities');
const education = await getCollection('education');
const certifications = await getCollection('certifications');

const sortById = <T extends { data: { id: number } }>(items: T[]) =>
  [...items].sort((a, b) => b.data.id - a.data.id);
---

<BaseLayout title="About" description="Software Engineer gw-lim입니다.">
  <article class="about-article">
    <div class="about-container">
      <header class="about-header">
        <div class="about-header-info">
          <div class="name-block">
            <h1 class="about-name">gw-lim</h1>
            <span class="about-korean">임건우</span>
          </div>
          <p class="about-role">Software Engineer</p>
          <div class="contact-grid">
            <div class="contact-row">
              <span class="contact-label">GitHub</span>
              <a
                href="https://github.com/gw-lim"
                target="_blank"
                rel="noopener"
                class="contact-value">github.com/gw-lim</a
              >
            </div>
            <div class="contact-row">
              <span class="contact-label">Phone</span>
              <span class="contact-value">010-7311-4513</span>
            </div>
            <div class="contact-row">
              <span class="contact-label">Email</span>
              <span class="contact-value">geonulim@gmail.com</span>
            </div>
            <div class="contact-row">
              <span class="contact-label">Education</span>
              <span class="contact-value">고려대학교 서울캠퍼스</span>
            </div>
            <div class="contact-row">
              <span class="contact-label">Blog</span>
              <a href="https://gw-lim.com" target="_blank" rel="noopener" class="contact-value"
                >gw-lim.com</a
              >
            </div>
            <div class="contact-row">
              <span class="contact-label">Location</span>
              <span class="contact-value">Seoul, Korea</span>
            </div>
          </div>
        </div>
        <div class="profile-photo">
          <img src="/images/profile-image.jpg" alt="gw-lim 프로필 사진" />
        </div>
      </header>

      <p class="about-summary">
        저는 소프트웨어 엔지니어 임건우입니다. 스타트업의 <strong>초기 창업 멤버</strong>로 합류하여
        백엔드부터 웹·앱·어드민까지 서비스 전 영역을 구축했고, <strong
          >6만+ 유저와 10억+ 원의 매출</strong
        >을 올리는데 기여했습니다. 운영 중인 핵심 도메인을 무중단으로 점진 분리하고 3계층 테스트
        인프라를 구축하며,
        <strong>비즈니스 가치와 코드 품질</strong>을 함께 끌어올리는 일에 주력하고 있습니다.
      </p>

      {
        careers.length > 0 && (
          <section class="about-section">
            <div class="section-head">
              <h2>Careers</h2>
            </div>
            <div class="about-section-body">
              {sortById(careers).map((item) => (
                <CareerItem item={item} />
              ))}
            </div>
          </section>
        )
      }

      {
        activities.length > 0 && (
          <section class="about-section">
            <div class="section-head">
              <h2>Activities</h2>
            </div>
            <div class="about-section-body">
              {sortById(activities).map((item) => (
                <ActivityItem item={item} />
              ))}
            </div>
          </section>
        )
      }

      {
        education.length > 0 && (
          <section class="about-section">
            <div class="section-head">
              <h2>Education</h2>
            </div>
            <div class="about-section-body">
              {sortById(education).map((item) => (
                <EducationItem item={item} />
              ))}
            </div>
          </section>
        )
      }

      {
        certifications.length > 0 && (
          <section class="about-section">
            <div class="section-head">
              <h2>Certifications</h2>
            </div>
            <div class="cert-grid">
              {sortById(certifications).map((item) => (
                <CertItem item={item} />
              ))}
            </div>
          </section>
        )
      }
    </div>
  </article>
</BaseLayout>

<style is:global>
  body:has(.about-article) main {
    max-width: none;
    padding-left: 0;
    padding-right: 0;
  }
</style>

<style>
  .about-article {
    --accent: #1d1d1f;
    --base: #2d2d2d;
    --base-80: rgba(45, 45, 45, 0.8);
    --base-60: rgba(45, 45, 45, 0.6);
    --base-30: rgba(45, 45, 45, 0.18);
    --hr: #e5e7eb;

    width: 100%;
    margin-bottom: 4rem;
    color: var(--base);
    font-family:
      'Pretendard',
      system-ui,
      -apple-system,
      sans-serif;
  }

  .about-container {
    margin: 0 auto;
    width: 100%;
    max-width: 72rem;
    padding: 3.5rem 1.5rem 5rem;
  }

  /* ─── HEADER ─── */
  .about-header {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2.75rem;
    padding-bottom: 2.75rem;
    border-bottom: 1px solid var(--hr);
  }

  .about-header-info {
    flex: 1;
  }

  .name-block {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.375rem;
  }

  .about-name {
    margin: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--accent);
    line-height: 1;
  }

  .about-korean {
    font-size: 1rem;
    font-weight: 500;
    color: var(--base-80);
    line-height: 1;
  }

  .about-role {
    margin: 0 0 1.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--base-60);
    letter-spacing: 0.01em;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem 2rem;
  }

  @media (min-width: 640px) {
    .contact-grid {
      grid-template-columns: repeat(3, minmax(0, auto));
      gap: 0.5rem 2.5rem;
    }
  }

  .contact-row {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .contact-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--base-60);
  }

  .contact-value {
    font-size: 0.8rem;
    color: var(--base);
    text-decoration: none;
  }

  .contact-value:hover {
    color: var(--accent);
  }

  /* ─── PROFILE PHOTO ─── */
  .profile-photo {
    flex-shrink: 0;
    width: 96px;
    aspect-ratio: 3 / 4;
    border: 1px solid var(--border, #e8e8e8);
    background: var(--bg-subtle, #f9f9f9);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    overflow: hidden;
  }

  .profile-photo svg {
    color: var(--base-30);
  }

  .profile-photo span {
    font-size: 0.6rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--base-60);
    font-weight: 500;
  }

  /* ─── SUMMARY ─── */
  .about-summary {
    margin: 0 0 3rem;
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--base);
  }

  .about-summary :global(strong) {
    color: var(--accent);
    font-weight: 600;
  }

  /* ─── SECTIONS ─── */
  .about-section {
    position: relative;
    width: 100%;
  }

  .about-section + .about-section {
    margin-top: 3rem;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.625rem;
    border-bottom: 2px solid var(--accent);
  }

  .section-head h2 {
    margin: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--accent);
  }

  .about-section-body {
    position: relative;
    width: 100%;
  }

  /* ─── CERT GRID ─── */
  .cert-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--hr);
    border: 1px solid var(--hr);
    border-radius: 6px;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .cert-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
