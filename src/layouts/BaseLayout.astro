---
import '../styles/global.css';
import GitHubIcon from '../components/icons/GitHubIcon.astro';
import LinkedInIcon from '../components/icons/LinkedInIcon.astro';

interface Props {
  title?: string;
  description?: string;
  thumbnail?: string;
}

const {
  title,
  description = 'Software Engineer gw-lim의 개발 블로그입니다.',
  thumbnail,
} = Astro.props;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;
const pageTitle = title ? `${title} | gw-lim` : 'gw-lim';
const ogTitle = title ?? 'gw-lim';

const pathname = Astro.url.pathname;
const isBlogActive = pathname === '/blog' || pathname.startsWith('/blog/');
const isResumeActive = pathname === '/resume' || pathname.startsWith('/resume/');

const githubUrl = 'https://github.com/gw-lim';
const linkedinUrl = 'https://www.linkedin.com/in/%EA%B1%B4%EC%9A%B0-%EC%9E%84-a994972a3/';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    {
      thumbnail && Astro.site && (
        <meta property="og:image" content={new URL(thumbnail, Astro.site)} />
      )
    }
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css"
      integrity="sha384-5TcZemv2l/9On385z///+d7MSYlvIEw9FuZTIdZ14vJLqWphw7e7ZPuOiCHJcFCP"
      crossorigin="anonymous"
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body class="flex min-h-screen flex-col antialiased">
    <header
      class="sticky top-0 z-50 border-b border-[var(--border)] bg-white/90 backdrop-blur-[10px]"
    >
      <nav class="mx-auto flex h-14 max-w-content items-center justify-between px-6">
        <a
          href="/"
          class="whitespace-nowrap font-mono text-[17px] font-bold tracking-[-0.02em] text-ink no-underline"
        >
          gw-lim
        </a>
        <div class="flex items-center gap-6">
          <a
            href="/blog"
            class:list={[
              'text-[14px] transition-colors duration-150',
              isBlogActive ? 'font-semibold text-ink' : 'font-medium text-ink-muted hover:text-ink',
            ]}>Blog</a
          >
          <a
            href="/resume"
            class:list={[
              'text-[14px] transition-colors duration-150',
              isResumeActive
                ? 'font-semibold text-ink'
                : 'font-medium text-ink-muted hover:text-ink',
            ]}>Resume</a
          >
          <span class="h-4 w-px bg-[var(--border-strong)]" aria-hidden="true"></span>
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener"
            class="flex items-center text-ink-faint transition-colors duration-150 hover:text-ink"
            aria-label="GitHub"
          >
            <GitHubIcon />
          </a>
          <a
            href={linkedinUrl}
            target="_blank"
            rel="noopener"
            class="flex items-center text-ink-faint transition-colors duration-150 hover:text-ink"
            aria-label="LinkedIn"
          >
            <LinkedInIcon />
          </a>
        </div>
      </nav>
    </header>
    <main class="mx-auto w-full max-w-content flex-1 px-6">
      <slot />
    </main>
    <footer class="border-t border-[var(--border)]">
      <div
        class="mx-auto flex max-w-content flex-wrap items-center justify-between gap-3 px-6 py-7"
      >
        <span class="text-[13px] text-ink-faint">
          © {new Date().getFullYear()} gw-lim. All rights reserved.
        </span>
        <div class="flex items-center gap-4">
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener"
            class="flex items-center gap-1.5 text-[12px] text-ink-faint no-underline transition-colors duration-150 hover:text-ink"
          >
            <GitHubIcon /> GitHub
          </a>
          <a
            href={linkedinUrl}
            target="_blank"
            rel="noopener"
            class="flex items-center gap-1.5 text-[12px] text-ink-faint no-underline transition-colors duration-150 hover:text-ink"
          >
            <LinkedInIcon /> LinkedIn
          </a>
        </div>
      </div>
    </footer>

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add('visible');
          });
        },
        { threshold: 0.08 },
      );
      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
