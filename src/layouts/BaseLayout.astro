---
import '../styles/global.css';
import GitHubIcon from '../components/icons/GitHubIcon.astro';

interface Props {
  title?: string;
  description?: string;
  thumbnail?: string;
}

const {
  title,
  description = 'Software Engineer gw-lim의 개발 블로그입니다.',
  thumbnail,
} = Astro.props;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;
const pageTitle = title ? `${title} | gw-lim` : 'gw-lim의 개발 블로그';
const ogTitle = title ?? 'gw-lim의 개발 블로그';
const ogImage = thumbnail ?? '/og-image.png';

const pathname = Astro.url.pathname;
const isBlogActive = pathname === '/blog' || pathname.startsWith('/blog/');
const isAboutActive = pathname === '/about' || pathname.startsWith('/about/');

const githubUrl = 'https://github.com/gw-lim';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    {Astro.site && <meta property="og:image" content={new URL(ogImage, Astro.site)} />}
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css"
      integrity="sha384-5TcZemv2l/9On385z///+d7MSYlvIEw9FuZTIdZ14vJLqWphw7e7ZPuOiCHJcFCP"
      crossorigin="anonymous"
    />
    <link rel="icon" type="image/svg+xml" sizes="16x16" href="/favicon16.svg" />
    <link rel="icon" type="image/svg+xml" sizes="32x32" href="/favicon32.svg" />
    <link rel="icon" type="image/svg+xml" sizes="64x64" href="/favicon64.svg" />
    <link rel="apple-touch-icon" href="/favicon64.svg" />
  </head>
  <body class="relative flex min-h-screen flex-col antialiased">
    <header
      class="sticky top-0 z-50 border-b border-[var(--border)] bg-white/90 backdrop-blur-[10px]"
    >
      <nav class="max-w-content mx-auto flex h-14 items-center justify-between px-6">
        <a
          href="/"
          class="text-ink whitespace-nowrap font-mono text-[17px] font-bold tracking-[-0.02em] no-underline"
        >
          gw-lim
        </a>
        <div class="flex items-center gap-6">
          <a
            href="/blog"
            class:list={[
              'text-[14px] transition-colors duration-150',
              isBlogActive ? 'text-ink font-semibold' : 'text-ink-muted hover:text-ink font-medium',
            ]}>Blog</a
          >
          <a
            href="/about"
            class:list={[
              'text-[14px] transition-colors duration-150',
              isAboutActive
                ? 'text-ink font-semibold'
                : 'text-ink-muted hover:text-ink font-medium',
            ]}>About</a
          >
          <span class="h-4 w-px bg-[var(--border-strong)]" aria-hidden="true"></span>
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener"
            class="text-ink-faint hover:text-ink flex items-center transition-colors duration-150"
            aria-label="GitHub"
          >
            <GitHubIcon />
          </a>
        </div>
      </nav>
    </header>
    <main class="max-w-content mx-auto w-full flex-1 px-6">
      <slot />
    </main>
    <slot name="aside" />
    <footer class="border-t border-[var(--border)]">
      <div
        class="max-w-content mx-auto flex flex-wrap items-center justify-between gap-3 px-6 py-7"
      >
        <span class="text-ink-faint text-[13px]">
          © {new Date().getFullYear()} gw-lim. All rights reserved.
        </span>
        <div class="flex items-center gap-4">
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener"
            class="text-ink-faint hover:text-ink flex items-center gap-1.5 text-[12px] no-underline transition-colors duration-150"
          >
            <GitHubIcon /> GitHub
          </a>
        </div>
      </div>
    </footer>

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add('visible');
          });
        },
        { threshold: 0.08 },
      );
      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
